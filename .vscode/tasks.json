{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build: dotnet",
      "type": "shell",
      "command": "dotnet build",
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test: dotnet",
      "type": "shell",
      "command": "dotnet test --no-build",
      "group": "test",
      "presentation": { "reveal": "always" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "db: migrate",
      "type": "shell",
      "command": "dotnet ef database update -p src\\api\\TCG.FreightBroker.Infrastructure -s src\\api\\TCG.FreightBroker.Api",
      "presentation": { "reveal": "always" }
    },
    {
      "label": "run: api",
      "type": "shell",
      "command": "dotnet run --project src\\api\\TCG.FreightBroker.Api",
      "isBackground": true,
      "presentation": { "reveal": "always" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run: web",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/src/web" },
      "isBackground": true,
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Start Everything",
      "dependsOn": ["db: migrate", "run: api", "run: web"],
      "dependsOrder": "sequence",
      "group": { "kind": "build", "isDefault": false },
      "presentation": { "reveal": "always" }
    },
    {
      "label": "Start Everything (skip migrate)",
      "dependsOn": ["run: api", "run: web"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": false },
      "presentation": { "reveal": "always" }
    }
  ]
}
