# Copy this file to .env and fill in values. Never commit .env.
# ---------------------------------------------------------------

# Local SQL Server Express — no Docker needed
ConnectionStrings__Default=Server=MTV-C39S774\SQLEXPRESS;Database=TcgFreightBroker;Integrated Security=True;TrustServerCertificate=True;

# JWT signing key (256-bit min — generate with: [Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)})))
Jwt__Key=REPLACE_WITH_32_BYTE_BASE64_SECRET
Jwt__Issuer=tcg-freight-broker
Jwt__Audience=tcg-freight-broker-client
Jwt__ExpiryMinutes=60

# Environment
ASPNETCORE_ENVIRONMENT=Development
